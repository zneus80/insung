rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 로그인한 사용자만 접근 가능
    function isAuthenticated() {
      return request.auth != null;
    }

    // 본인 여부
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // 역할 조회 (users 컬렉션에서)
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isHrAdmin() {
      let d = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return d.isHrAdmin == true || d.role == 'HR_ADMIN';
    }
    function isHrMaster() {
      let d = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return d.isHrMaster == true;
    }
    function isCeo()     { return getRole() == 'CEO'; }
    function isExec()    { return getRole() == 'EXECUTIVE'; }
    function isLead()    { return getRole() == 'TEAM_LEAD'; }
    function isMember()  { return getRole() == 'MEMBER'; }

    // 본인 소속 조직(팀) id — 팀 공유 주간보고 권한 판정용
    function userOrg() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId;
    }

    // 사용자
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid) || isHrAdmin() || isCeo();
    }

    // 조직
    match /organizations/{orgId} {
      allow read: if isAuthenticated();
      allow write: if isHrAdmin() || isCeo();
    }

    // 목표
    match /goals/{goalId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        // 공동과제: 같은 팀(조직) 멤버가 주간보고에서 진행률 역류 (v0.9 팀공유)
        resource.data.organizationId == userOrg() ||
        isLead() || isExec() || isCeo() || isHrAdmin()
      );
    }

    // 목표 이력 (읽기 전용)
    match /goalHistories/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // 진행상황
    match /progressUpdates/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
    }

    // 1on1
    match /oneOnOnes/{id} {
      // 1on1 은 사적 대화 — 당사자(팀장/팀원)만 조회 가능. (백업은 Admin SDK 경유)
      allow read: if isAuthenticated() && (
        resource.data.leaderId == request.auth.uid ||
        resource.data.memberId == request.auth.uid
      );
      allow write: if isAuthenticated() && (
        resource == null ||
        resource.data.leaderId == request.auth.uid ||
        resource.data.memberId == request.auth.uid
      );
    }

    // 조직 평가
    match /orgEvaluations/{id} {
      allow read: if isAuthenticated();
      allow write: if isHrAdmin() || isCeo();
    }

    // 개인 평가 — 읽기 권한 잠금 (v0.10, 옵션 E API 프록시):
    //  · 일반 read 는 서버 API(/api/evaluation/individual, Admin SDK)를 경유한다.
    //    서버가 조직 체인 스코프로 권한을 판정하므로 클라이언트 직접 조회는 불필요.
    //  · 클라이언트 직접 조회는 HR(관리자·마스터)·CEO 만 허용
    //    (팀장·임원의 콘솔/curl 우회 대량조회 차단 — 정보탈취 방지).
    //  · 팀원·팀장·임원의 정상 조회는 전부 프록시 경유(스코프 적용)되므로 영향 없음.
    match /individualEvaluations/{id} {
      allow read: if isAuthenticated() && (isHrAdmin() || isHrMaster() || isCeo());
      allow write: if isAuthenticated() && (
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid) ||
        isLead() || isExec() || isCeo() || isHrAdmin()
      );
    }

    // 자기평가 (docId = userId_year) — read 잠금 (옵션 E Phase 3):
    //  본인(docId) + HR/CEO 만 직접 read. 팀장·임원 조회는 /api/evaluation/forms 프록시 경유.
    match /selfEvaluations/{docId} {
      allow read: if isAuthenticated() && (
        docId.matches('^' + request.auth.uid + '_.*') ||
        isHrAdmin() || isHrMaster() || isCeo()
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 평가 사이클
    match /evaluationCycles/{id} {
      allow read: if isAuthenticated();
      allow write: if isHrAdmin();
    }

    // 등급 쿼터
    match /gradeQuotas/{id} {
      allow read: if isAuthenticated();
      allow write: if isHrAdmin();
    }

    // 연간 목표 (회사/조직)
    match /annualGoals/{id} {
      allow read: if isAuthenticated();
      allow write: if isHrAdmin();
    }

    // 마일리지
    match /mileages/{userId} {
      // 조직현황 공유 목적 — 인증된 모든 사용자가 마일리지 점수 조회 가능 (쓰기는 HR/CEO 한정)
      allow read: if isAuthenticated();
      allow write: if isHrAdmin() || isCeo();
    }

    // 1on1 Q&A 서브컬렉션 — 부모 1on1 의 당사자만
    match /oneOnOnes/{id}/questions/{qId} {
      allow read: if isAuthenticated() && (
        get(/databases/$(database)/documents/oneOnOnes/$(id)).data.leaderId == request.auth.uid ||
        get(/databases/$(database)/documents/oneOnOnes/$(id)).data.memberId == request.auth.uid
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // 부문/공장 등급 변경 이력
    match /orgGradeHistories/{id} {
      allow read: if isAuthenticated();
      allow create: if isCeo();
    }

    // 부문/공장별 개인 등급 쿼터
    match /divisionGradeQuotas/{id} {
      allow read: if isAuthenticated();
      allow write: if isHrAdmin() || isCeo();
    }

    // 초대 토큰 (토큰을 아는 사람만 읽기 가능 - UUID가 보안 역할)
    match /invitations/{token} {
      allow read: if true;
      allow create: if isHrAdmin() || isCeo();
      allow update: if true; // 초대 수락 시 usedAt 업데이트
    }

    // 알림
    match /notifications/{id} {
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 주간 업무 (v0.9: 팀 공유 문서 docId = teamOrgId_year_Wnn / 레거시 개인 문서 userId_year_Wnn 공존)
    match /weeklyTasks/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        // 팀 공유 문서 — 본인 소속 팀의 문서 생성
        request.resource.data.organizationId == userOrg()
        ||
        // 레거시 개인 문서
        request.resource.data.userId == request.auth.uid
      );
      allow update: if isAuthenticated() && (
        // 같은 팀(조직) 멤버 — 팀 공유 폼 편집(누구나)
        resource.data.organizationId == userOrg()
        ||
        // 레거시 본인 문서
        resource.data.userId == request.auth.uid
        ||
        // 팀장·임원이 leadComments 만 추가 — 본문·소유권 불변
        (
          request.resource.data.organizationId == resource.data.organizationId &&
          request.resource.data.year           == resource.data.year           &&
          request.resource.data.weekNumber     == resource.data.weekNumber     &&
          request.resource.data.hasDoneItems   == resource.data.hasDoneItems   &&
          request.resource.data.willDoItems    == resource.data.willDoItems
        )
      );
      allow delete: if isAuthenticated() && (
        resource.data.organizationId == userOrg() ||
        resource.data.userId == request.auth.uid
      );
    }

    // 연말 평가 (docId = userId_year) — read 잠금 (옵션 E Phase 3): 본인 + HR/CEO 만 직접.
    match /yearEndEvals/{docId} {
      allow read: if isAuthenticated() && (
        docId.matches('^' + request.auth.uid + '_.*') ||
        isHrAdmin() || isHrMaster() || isCeo()
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 평가 기간 설정 (HR관리자·CEO가 설정, 전체가 읽기)
    match /evaluationPeriods/{docId} {
      allow read: if isAuthenticated();
      allow write: if isHrAdmin() || isCeo();
    }

    // 육성면담서 (docId = userId_year) — read 잠금 (옵션 E Phase 3):
    //  본인 + HR/CEO 만 직접. 팀장·임원 조회는 /api/evaluation/forms 프록시 경유.
    match /mentoringForms/{docId} {
      allow read: if isAuthenticated() && (
        docId.matches('^' + request.auth.uid + '_.*') ||
        isHrAdmin() || isHrMaster() || isCeo()
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // 본인 작성/수정 OR HR관리자가 수정 요청 승인/거절 처리
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isHrAdmin()
      );
    }

    // 공지사항 (전체 읽기, HR관리자만 쓰기)
    match /announcements/{id} {
      allow read: if isAuthenticated();
      allow write: if isHrAdmin();
    }

    // 포상 이력 (전체 읽기, HR관리자만 쓰기)
    match /awards/{id} {
      allow read: if isAuthenticated();
      allow write: if isHrAdmin();
    }

    // 혁신활동 (전사 읽기, HR관리자만 쓰기)
    match /innovationActivities/{id} {
      allow read: if isAuthenticated();
      allow write: if isHrAdmin();
    }

    // 시스템 설정 (전체 읽기, HR관리자만 쓰기)
    match /systemSettings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isHrAdmin();
    }

    // 데이터 백업 (HR관리자만 읽기·쓰기·삭제)
    match /backups/{id} {
      allow read: if isHrAdmin();
      allow create: if isHrAdmin();
      allow delete: if isHrAdmin();
    }

    // 감사 로그 (HR 마스터·최고관리자만 읽기 / HR관리자·최고관리자·본인 행위는 생성 가능 / 삭제 금지)
    match /auditLogs/{id} {
      allow read: if isHrMaster() || isCeo();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
